# Example environment overrides for scenario E2E tests
# Copy to .env.e2e.scenarios or .env.e2e.scenarios.local and fill in secrets

# Enable running scenario tests automatically (otherwise set RUN_SCENARIO_E2E=1 inline)
RUN_SCENARIO_E2E=1

# Real embeddings + chat model
GOOGLE_API_KEY=REDACTED_GOOGLE_API_KEY_2
CHAT_MODEL_ENABLED=true
