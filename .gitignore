# ============================================================
# AI tool local state and settings
# ============================================================
# These directories contain API keys, session data, or local
# preferences that must never be committed to a public repo.

# Gemini CLI (may contain API keys in settings.json)
.gemini/

# Cursor IDE
.cursor/

# Claude Code
.claude/

# Copilot
.copilot/

# OpenCode session database (contains full conversation history)
.opencode/opencode.db
.opencode/opencode.db-shm
.opencode/opencode.db-wal

# OpenCode tools that reference old monorepo / read .env at runtime
.opencode/tool/

# General database files that may appear from tools
*.sqlite
*.sqlite3

# ============================================================
# Environment and secrets
# ============================================================

# Environment files with secrets (never commit)
.env
.env.local
**/.env.local
.env.infisical
.env.staging
.env.production

# Note: .env.example files WITH SAFE DEFAULTS are committed.
# All secrets should be in .env / .env.local files only.

# Secrets directory
secrets/
!secrets/README.md

# Private keys
*.pem
*.private-key.pem
apps/epf-cli/private-key.pem

# ============================================================
# OS / IDE / build
# ============================================================

.DS_Store
.idea/
.nx/
.vite/
**/.vite/
*.log
*.tsbuildinfo

# ============================================================
# Build outputs
# ============================================================

# Ignore build outputs in all packages
apps/server-nest/dist/
apps/server-nest/dist-openapi/
**/dist-openapi/

# ============================================================
# Test artifacts
# ============================================================

# Database backups and schema dumps
backups/

# Playwright / E2E artifacts
playwright-report/
**/playwright-report/
test-results/
**/test-results/
/.cache/ms-playwright/
**/.cache/ms-playwright/

# Coverage outputs
coverage/
**/coverage/
lcov.info

# Vitest / Jest snapshots (optional keep if needed)
*.snap

# ============================================================
# Project-specific
# ============================================================

# Server runtime logs
apps/server-nest/logs/

# Development PID files
.dev-pids/
apps/pids/

storybook-static
logs
apps/server-nest/migrations/_archive_*/

# Duplicate detection reports
/reports/jscpd/

# EPF eval reports (generated per run, not committed)
eval/epf-model-compliance/reports/

# EPF CLI venv
eval/epf-model-compliance/.venv/

# EPF CLI secrets (runtime .env with real credentials)
apps/epf-cli/.env

# EPF CLI test artifacts
apps/epf-cli/epf-cli-test
apps/epf-cli/internal/mcp/AIM/

