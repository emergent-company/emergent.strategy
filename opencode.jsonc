{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex-anthropic/claude-opus-4-6",
  "provider": {
    "google-vertex-anthropic": {
      "options": {
        "project": "legalplant-dev",
        "location": "global",
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Vertex AI)",
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Vertex AI)",
        },
      },
    },
  },
  // EPF MCP server and LSP are configured globally in ~/.config/opencode/opencode.json
  "instructions": [".opencode/instructions.md"],
  "mcp": {
    // strategy-server — local dev instance (start with: cd apps/strategy-server && task dev-up)
    "strategy-server": {
      "type": "remote",
      "url": "http://localhost:8090/mcp",
      "enabled": true,
      "timeout": 60000,
    },
  },
  "tools": {
    "todowrite": true,
    "webfetch": true,
  },
}
