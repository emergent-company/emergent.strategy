{
  "name": "strategy-server-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind CSS build for strategy-server web UI",
  "scripts": {
    "build": "cd .. && node web/node_modules/.bin/tailwindcss -i web/app.css -o web/staticfiles/static/css/app.css --minify",
    "watch": "cd .. && node web/node_modules/.bin/tailwindcss -i web/app.css -o web/staticfiles/static/css/app.css --watch"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify/tailwind4": "^1.2.3",
    "daisyui": "^5.5.19"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2"
  }
}
