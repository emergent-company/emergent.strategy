# EPF Cloud Server — Environment Variables
# Copy this file to .env and fill in your values.
#
# For full documentation see the "Cloud Server (Self-Hosting)" section in README.md.

# ---------------------------------------------------------------------------
# GitHub App Authentication (required for cloud mode)
# ---------------------------------------------------------------------------

# GitHub App ID (numeric). Found on the app settings page.
EPF_GITHUB_APP_ID=

# Path to the GitHub App private key PEM file.
# When using docker-compose, this is overridden to /secrets/private-key.pem
# (mounted as a volume). Place your .pem file as ./private-key.pem.
# Alternatively, paste the full PEM content inline (must start with "-----BEGIN").
EPF_GITHUB_APP_PRIVATE_KEY=./private-key.pem

# GitHub App installation ID (numeric).
# Find it in the URL after installing: /organizations/YOUR-ORG/settings/installations/INSTALLATION_ID
EPF_GITHUB_APP_INSTALLATION_ID=

# ---------------------------------------------------------------------------
# GitHub Repository
# ---------------------------------------------------------------------------

# GitHub organization or user that owns the EPF repository.
EPF_GITHUB_OWNER=your-org

# Repository name containing the EPF instance.
EPF_GITHUB_REPO=your-epf-repo

# (Optional) Branch, tag, or SHA to read from. Defaults to the repo's default branch.
# EPF_GITHUB_REF=main

# (Optional) Path within the repo to the EPF instance root.
# Only needed if the instance is not at the repository root.
# EPF_GITHUB_BASE_PATH=docs/EPF/_instances/my-product

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# HTTP port. Cloud Run sets this automatically; override for local Docker runs.
PORT=8080

# (Optional) Human-readable name shown in the /health response.
# EPF_INSTANCE_NAME=My Team EPF Server

# (Optional) CORS allowed origins, comma-separated. Default: * (all origins).
# EPF_CORS_ORIGINS=https://example.com,https://app.example.com
